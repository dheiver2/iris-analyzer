# Copie para .env (ou exporte no shell) para sobrescrever a configuração
# padrão em iris_analyzer/config.py. Nenhuma destas variáveis é obrigatória.

# --- Web app (server.py / run_web.py) ---
# Host/porta do servidor. Use 0.0.0.0 apenas se souber o que está fazendo
# (ver SECURITY.md) — o padrão 127.0.0.1 mantém o servidor local.
IRIS_WEB_HOST=127.0.0.1
IRIS_WEB_PORT=8000
# Tamanho máximo de upload de imagem, em MB.
IRIS_MAX_UPLOAD_MB=15
# Origens extras permitidas via CORS, separadas por vírgula. Vazio (padrão)
# = sem CORS extra (mesma origem apenas).
IRIS_CORS_ORIGINS=

# --- Modelo MediaPipe ---
# Caminho alternativo para o face_landmarker.task já baixado.
IRIS_MODELO=

# --- Câmera (app desktop) ---
IRIS_CAMERA=0
IRIS_CAM_W=1920
IRIS_CAM_H=1080
